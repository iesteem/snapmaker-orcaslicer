msgstr "最后一层在打印平台上方的Z高度。"

msgid "Filament extruder ID"
msgstr "耗材挤出机ID"

msgid "The current extruder ID. The same as current_extruder."
msgstr "当前挤出机ID。与current_extruder相同。"

msgid "Error in zip archive"
msgstr "压缩包错误"

msgid "Generating walls"
msgstr "生成壁"

